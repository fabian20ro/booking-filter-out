{
  "manifest_version": 3,
  "name": "Filter Booking.com results for Hotels that forbid Animals",
  "version": "1.1",
  "description": "Filter for Booking.com properties that forbid animals",
  "icons": {
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "booking-filter-out@fabian20ro.github.io",
      "strict_min_version": "109.0"
    }
  },
    "content_scripts": [
      {
        "matches": ["*://*.booking.com/searchresults*"],
        "js": ["content.js"],
        "css": ["style.css"]
      }
    ],
  "permissions": ["storage"]
}
